# Environment variables for the RFP SPA (Vite frontend)
# Copy this file to .env and fill in the values before running.

# ─── Required ───────────────────────────────────────────────────────────────

# Microsoft Foundry project endpoint (found in AI Foundry portal > Project overview)
# Format: https://<ai-services-account>.services.ai.azure.com/api/projects/<project-name>
VITE_FOUNDRY_PROJECT_ENDPOINT=https://your-account.services.ai.azure.com/api/projects/your-project

# Entra ID app registration for browser authentication
# Create an app registration in Azure Portal > Entra ID > App registrations
# with a SPA redirect URI (e.g. http://localhost:5173 for development).
# Grant API permission: Cognitive Services User (https://cognitiveservices.azure.com/.default)
VITE_ENTRA_CLIENT_ID=<your-entra-app-client-id>
VITE_ENTRA_TENANT_ID=<your-entra-tenant-id>
