# Environment variables for the RFP Agent
# Copy this file to .env and fill in the values before running.

# --- Required ---

# Microsoft Foundry project endpoint (found in AI Foundry portal > Project overview)
# Format: https://<ai-services-account>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_PROJECT_ENDPOINT=https://your-account.services.ai.azure.com/api/projects/your-project

# Name of the GPT model deployment in your Foundry project (Models + endpoints > Name column)
FOUNDRY_MODEL_NAME=gpt-5.1

# --- Optional ---

# URL of the MCP procurement server (default: http://localhost:3000)
MCP_SERVER_URL=http://localhost:3000

# Directory where the output files (Excel, text) will be saved (default: ./output)
OUTPUT_DIR=./output
