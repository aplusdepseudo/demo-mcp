{
  "name": "mcp-mock",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "mcp-mock": "./build/index.js"
  },
  "config": {
    "resourceGroup": "demo-agentic-rg",
    "resourceWebApp": "demo-agentic-wa"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "npx tsx watch src/index.ts",
    "build": "tsc",
    "rebuild-arm": "az bicep build --file infra/main.bicep --outfile infra/main.json",
    "deploy-infra": "az deployment group create --resource-group %npm_package_config_resourceGroup% --template-file infra/main.bicep --parameters infra/main.bicepparam",
    "package-app": "tar -cavf ./package/build.zip -C ./build/ *",
    "predeploy-app": "npm run build && npm run package-app",
    "deploy-app": "az webapp deploy --name %npm_package_config_resourceWebApp% --resource-group %npm_package_config_resourceGroup% --src-path ./package/build.zip --type zip",
    "inspect": "npx -y @modelcontextprotocol/inspector"
  },
  "keywords": [],
  "author": "Nicolas ANTOINE",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "tsx": "^4.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.3",
    "typescript": "^5.9.3"
  }
}
